{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "feature.schema.json",
  "type": "object",
  "required": ["id", "title", "category", "moscow", "priority", "status", "release", "createdAt", "updatedAt", "tags", "type", "progress"],
  "properties": {
    "id": { "type": "string", "pattern": "^FEAT\\d{3,}$" },
    "title": { "type": "string", "minLength": 1 },
    "category": { "type": "string", "minLength": 1 },
    "moscow": { "enum": ["MUST", "SHOULD", "COULD", "WONT"] },
    "priority": { "type": ["integer", "null"], "minimum": 1 },
    "status": { "enum": ["Planned", "Design Reviewed", "In Progress", "Code Reviewed", "Testing", "Done", "Rejected"] },
    "release": { "type": ["string", "null"] },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "tags": { "type": "array", "items": { "type": "string" } },
    "okrLink": { "type": ["string", "null"] },
    "type": { "enum": ["feature", "bug"], "default": "feature" },
    "description": { "type": ["string", "null"] },
    "complexity": { "enum": ["low", "medium", "high", "very-high", null] },
    "progress": { "type": "integer", "minimum": 0, "maximum": 100, "default": 0 },
    "notes": { "type": ["string", "null"] },
    "specFile": { "type": ["string", "null"] },
    "githubIssue": { "type": ["integer", "null"] }
  },
  "additionalProperties": false
}
